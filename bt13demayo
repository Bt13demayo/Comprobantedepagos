<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Comprobantes - Barrio Transitorio 13 de Mayo</title>

<style>
body {
  font-family: Arial, sans-serif;
  background: #eef1f5;
  padding: 30px;
}

.container {
  max-width: 650px;
  margin: auto;
  background: #fff;
  padding: 25px;
  border-radius: 10px;
  box-shadow: 0 0 15px rgba(0,0,0,0.1);
}

h2 {
  text-align: center;
}

input, select {
  width: 100%;
  padding: 10px;
  margin: 6px 0;
}

button {
  padding: 10px;
  margin-top: 10px;
  width: 48%;
  cursor: pointer;
}

.row {
  display: flex;
  justify-content: space-between;
}

.comprobante {
  margin-top: 25px;
  border: 2px solid #000;
  padding: 20px;
}

.header {
  text-align: center;
  border-bottom: 2px solid #000;
  margin-bottom: 15px;
}

.numero {
  text-align: right;
  font-weight: bold;
}

.footer {
  margin-top: 25px;
  font-size: 12px;
  text-align: center;
}

/* 🔥 SOLO IMPRIME EL COMPROBANTE */
@media print {
  body * {
    visibility: hidden;
  }

  .comprobante, .comprobante * {
    visibility: visible;
  }

  .comprobante {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    border: none;
  }

  body {
    background: white;
  }
}
</style>

</head>
<body>

<div class="container">
  <h2>Generador de Comprobantes</h2>

  <input type="text" id="nombre" placeholder="Nombre">
  <input type="text" id="apellido" placeholder="Apellido">
  <input type="text" id="telefono" placeholder="Teléfono">

  <input type="text" id="detalle" placeholder="Detalle del pago">
  <input type="number" id="monto" placeholder="Monto">

  <select id="tipoPago">
    <option value="Efectivo">Efectivo</option>
    <option value="Transferencia">Transferencia</option>
  </select>

  <input type="text" id="operacion" placeholder="N° Operación / Transferencia">

  <div class="row">
    <button onclick="generar()">Generar</button>
    <button onclick="imprimir()">Imprimir / PDF</button>
  </div>

  <div id="resultado"></div>
</div>

<script>
let numero = localStorage.getItem("contador_barrio") || 1;

function generar() {
  let nombre = document.getElementById("nombre").value;
  let apellido = document.getElementById("apellido").value;
  let telefono = document.getElementById("telefono").value;
  let detalle = document.getElementById("detalle").value;
  let monto = document.getElementById("monto").value;
  let tipoPago = document.getElementById("tipoPago").value;
  let operacion = document.getElementById("operacion").value;

  if (!nombre || !apellido || !telefono || !monto) {
    alert("Completa los campos obligatorios");
    return;
  }

  let fecha = new Date();
  let fechaTexto = fecha.toLocaleDateString() + " " + fecha.toLocaleTimeString();

  let comprobanteHTML = `
    <div class="comprobante">

      <div class="header">
        <h3>BARRIO TRANSITORIO 13 DE MAYO</h3>
        <p><strong>Comprobante de Pago</strong></p>
      </div>

      <div class="numero">
        N° ${numero}
      </div>

      <p><strong>Fecha:</strong> ${fechaTexto}</p>

      <p><strong>Nombre:</strong> ${nombre} ${apellido}</p>
      <p><strong>Teléfono:</strong> ${telefono}</p>

      <hr>

      <p><strong>Detalle:</strong> ${detalle}</p>

      <hr>

      <p><strong>Tipo de Pago:</strong> ${tipoPago}</p>
      <p><strong>N° Operación:</strong> ${operacion || "N/A"}</p>

      <hr>

      <h2>Total: $${parseInt(monto).toLocaleString()}</h2>

      <div class="footer">
        Documento interno de control - Barrio Transitorio 13 de Mayo
      </div>

    </div>
  `;

  document.getElementById("resultado").innerHTML = comprobanteHTML;

  numero++;
  localStorage.setItem("contador_barrio", numero);
}

function imprimir() {
  window.print();
}
</script>

</body>
</html>
